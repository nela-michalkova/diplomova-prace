@BOOK{Kop-Dal:2004:LaTeXPodrPruv:,
  author =	 "H. Kopka" #and# "P.~W. Daly",
  title =	 "{{\LaTeX}. Podrobný průvodce}",
  publisher =	 "Computer Press",
  year =	 "2004",
  address =	 "Brno",
  edition =	 "\bblfirsto{}",
  pages =	 "584",
  isbn =	 "80-722-6973-9",
  annote =	 "Pokud potřebujete profesionálně zpracovat text pro tiskový
                  výstup, s~touto knihou, která je překladem světově
                  proslulého titulu \uv{A Guide to {\LaTeX}}, zvládnete i~ty
                  nejsložitější operace s~textem. Sázení textu pomocí programu
                  {\LaTeX} je specifické především přímým využíváním
                  značkovacího jazyka, kterým se vyřazují nepřesnosti editorů
                  založených na technice WYSIWYG.  {\LaTeX} je programem,
                  který se pro své mimořádné schopnosti v~technice zalamování,
                  speciálních znaků nebo matematických vzorců prosadil
                  především v~akademické sféře. Kniha nejenže přináší
                  podrobný, názorný a srozumitelný výklad, ale také pečlivě
                  zohledňuje rozdíly mezi verzemi {\LaTeX} verze
                  $2_{\varepsilon}$ a $2.09$. Příklady jsou vždy výrazně
                  odděleny a označeny rozdíly ve verzích. Kniha je rozdělena
                  do přehledných kapitol s praktickými příklady",
  language =	 "czech",
}

